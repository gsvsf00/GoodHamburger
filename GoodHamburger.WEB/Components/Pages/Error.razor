@page "/Error"
@using System.Diagnostics

<PageTitle>Erro</PageTitle>

<h1 class="text-danger">Erro.</h1>
<h2 class="text-danger">Ocorreu um erro ao processar sua solicitacao.</h2>

@if (ShowRequestId)
{
    <p>
        <strong>ID da solicitacao:</strong> <code>@RequestId</code>
    </p>
}

<h3>Modo de desenvolvimento</h3>
<p>
    Alterar para o ambiente <strong>Development</strong> exibira informacoes mais detalhadas sobre o erro ocorrido.
</p>
<p>
    <strong>O ambiente Development nao deve ser habilitado em aplicacoes publicadas.</strong>
    Isso pode expor informacoes sensiveis de excecoes para usuarios finais.
    Para depuracao local, habilite o ambiente <strong>Development</strong> definindo a variavel <strong>ASPNETCORE_ENVIRONMENT</strong> como <strong>Development</strong>
    e reinicie a aplicacao.
</p>

@code{
    [CascadingParameter]
    private HttpContext? HttpContext { get; set; }

    private string? RequestId { get; set; }
    private bool ShowRequestId => !string.IsNullOrEmpty(RequestId);

    protected override void OnInitialized() =>
        RequestId = Activity.Current?.Id ?? HttpContext?.TraceIdentifier;
}
